// ===== PINES =====
const int KEY_PINS[6] = {4, 5, 12, 13, 14, 15};
const int POT_PINS[2] = {32, 33};

// ===== ESTADO =====
String keyMacros[6] = {"", "", "", "", "", ""};
String potFunctions[2] = {"VOLUMEN", "BRILLO"};

unsigned long lastDebounceTime[6] = {0};
const unsigned long debounceDelay = 50;
int lastButtonState[6] = {HIGH, HIGH, HIGH, HIGH, HIGH, HIGH};

int lastPotValue[2] = {2048, 2048};
const int potThreshold = 300;
unsigned long lastPotAction = 0;
const unsigned long potCooldown = 200;

// ===== CÓDIGOS HID =====
#define HID_KEY_A    0x04
#define HID_KEY_C    0x06
#define HID_KEY_R    0x15
#define HID_KEY_S    0x16
#define HID_KEY_V    0x19
#define HID_KEY_Z    0x1D
#define HID_KEY_1    0x1E
#define HID_KEY_2    0x1F
#define HID_KEY_3    0x20
#define HID_KEY_4    0x21
#define HID_KEY_5    0x22
#define HID_KEY_6    0x23
#define HID_KEY_7    0x24
#define HID_KEY_8    0x25
#define HID_KEY_9    0x26
#define HID_KEY_0    0x27
#define HID_KEY_RETURN 0x28
#define HID_KEY_TAB  0x2B
#define HID_KEY_SPACE 0x2C
#define HID_KEY_MINUS 0x2D
#define HID_KEY_EQUAL 0x2E
#define HID_KEY_COMMA 0x36
#define HID_KEY_PERIOD 0x37
#define HID_KEY_SLASH 0x38

#define KEY_LEFT_CTRL  0x01
#define KEY_LEFT_SHIFT 0x02
#define KEY_LEFT_ALT   0x04
#define KEY_LEFT_GUI   0x08

#define CONSUMER_VOLUME_UP      0x00E9
#define CONSUMER_VOLUME_DOWN    0x00EA
#define CONSUMER_BRIGHTNESS_UP  0x006F
#define CONSUMER_BRIGHTNESS_DOWN 0x0070

// ===== CALLBACKS =====
class MyServerCallbacks : public BLEServerCallbacks {
  void onConnect(BLEServer* pServer) {
    bleConnected = true;
    Serial.println("BLE Conectado!");
    updateDisplay("BLE Conectado", "Listo");
  }
  void onDisconnect(BLEServer* pServer) {
    bleConnected = false;
    Serial.println("BLE Desconectado");
    updateDisplay("BLE Desconectado", "Reconectando...");
    delay(500);
    BLEDevice::startAdvertising();
  }
};

// ===== SETUP =====
void setup() {
  Serial.begin(115200);
  delay(100);

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("[ERROR] OLED");
  } else {
    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(SSD1306_WHITE);
    display.setCursor(0,0);
    display.println("Teclado Macros");
    display.println("Iniciando BLE...");
    display.display();
  }

  BLEDevice::init("Teclado Macros");
  BLEServer* pServer = BLEDevice::createServer();
  pServer->setCallbacks(new MyServerCallbacks());

  hidDevice = new BLEHIDDevice(pServer);
  inputKeyboard = hidDevice->inputReport(1);
  inputMedia = hidDevice->inputReport(2);
  
  hidDevice->reportMap((uint8_t*)reportDescriptor, sizeof(reportDescriptor));
  hidDevice->manufacturer()->setValue("ESP32");
  hidDevice->pnp(0x02, 0xe502, 0xa111, 0x0210);
  hidDevice->hidInfo(0x00, 0x01);
  hidDevice->startServices();

  BLEAdvertising* pAdvertising = pServer->getAdvertising();
  pAdvertising->setAppearance(HID_KEYBOARD);
  pAdvertising->addServiceUUID(hidDevice->hidService()->getUUID());
  pAdvertising->setScanResponse(true);
  pAdvertising->start();

  hidDevice->setBatteryLevel(100);
  Serial.println("READY");

  for (int i = 0; i < 6; i++) pinMode(KEY_PINS[i], INPUT_PULLUP);
  for (int i = 0; i < 2; i++) {
    pinMode(POT_PINS[i], INPUT);
    lastPotValue[i] = analogRead(POT_PINS[i]);
  }

  updateDisplay("BLE Listo", "Emparejar PC");
}

// ===== LOOP =====
void loop() {
  checkSerialCommands();
  if (bleConnected) {
    checkKeys();
    checkPotentiometers();
  }
}

// ===== OLED =====
void updateDisplay(String line1, String line2) {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(0,0);
  display.println(line1);
  display.setCursor(0,10);
  display.println(line2);
  display.setCursor(0,22);
  display.print(bleConnected ? "BLE:OK " : "BLE:-- ");
  display.print("T:");
  for (int i = 0; i < 6; i++) {
    display.print(digitalRead(KEY_PINS[i]) == LOW ? "#" : "-");
  }
  display.display();
}

// ===== ENVIAR TECLA =====
void sendKey(uint8_t key, uint8_t modifier) {
  if (!bleConnected) return;
  uint8_t report[8] = {0};
  report[0] = modifier;
  report[2] = key;
  inputKeyboard->setValue(report, 8);
  inputKeyboard->notify();
  delay(50);
  uint8_t empty[8] = {0};
  inputKeyboard->setValue(empty, 8);
  inputKeyboard->notify();
}

// ===== ENVIAR TECLA MULTIMEDIA =====
void sendMediaKey(uint16_t key) {
  if (!bleConnected) return;
  uint8_t report[2] = {0};
  report[0] = key & 0xFF;
  report[1] = (key >> 8) & 0xFF;
  inputMedia->setValue(report, 2);
  inputMedia->notify();
  delay(50);
  uint8_t empty[2] = {0};
  inputMedia->setValue(empty, 2);
  inputMedia->notify();
}

// ===== EJECUTAR MACRO =====
void executeMacro(String macro) {
  if (macro.length() == 0 || !bleConnected) return;

  if (macro == "Ctrl+C") {
    sendKey(HID_KEY_C, KEY_LEFT_CTRL);
  } else if (macro == "Ctrl+V") {
    sendKey(HID_KEY_V, KEY_LEFT_CTRL);
  } else if (macro == "Ctrl+Z") {
    sendKey(HID_KEY_Z, KEY_LEFT_CTRL);
  } else if (macro == "Ctrl+S") {
    sendKey(HID_KEY_S, KEY_LEFT_CTRL);
  } else if (macro == "Alt+Tab") {
    sendKey(HID_KEY_TAB, KEY_LEFT_ALT);
  } else if (macro == "Chrome" || macro == "Spotify" || macro == "Calculadora") {
    sendKey(HID_KEY_R, KEY_LEFT_GUI);
    delay(400);
    String app = (macro == "Chrome") ? "chrome\n" : (macro == "Spotify") ? "spotify\n" : "calc\n";
    for (char c : app) {
      sendKey(getKey(c), 0);
      delay(30);
    }
    delay(300);
    sendKey(HID_KEY_RETURN, 0);
  } else if (macro.startsWith("URL:")) {
    String url = macro.substring(4);
    
    // Abrir con Win+R - Windows reconoce URLs y las abre en el navegador
    sendKey(HID_KEY_R, KEY_LEFT_GUI);
    delay(400);
    
    // Escribir la URL completa con mapeo de teclado español
    for (char c : url) {
      uint8_t key = getKey(c);
      bool needsShift = (c == '?' || c == '&' || c == '%' || c == '#' || c == '_' || c == '=' || c == ':' || c == '/');
      if (needsShift) {
        sendKey(key, KEY_LEFT_SHIFT);
      } else {
        sendKey(key, 0);
      }
      delay(30);
    }
    delay(300);
    sendKey(HID_KEY_RETURN, 0);
  }
}

// ===== MAPEO DE TECLADO ESPAÑOL =====
uint8_t getKey(char c) {
  // Letras
  if (c >= 'a' && c <= 'z') return HID_KEY_A + (c - 'a');
  if (c >= 'A' && c <= 'Z') return HID_KEY_A + (c - 'A');
  // Números (no necesitan Shift)
  if (c >= '1' && c <= '9') return HID_KEY_1 + (c - '1');
  if (c == '0') return HID_KEY_0;
  // Símbolos que NO necesitan Shift en español
  if (c == '.') return HID_KEY_PERIOD;
  if (c == '-') return HID_KEY_MINUS;
  // Símbolos que SÍ necesitan Shift en español
  if (c == ':') return HID_KEY_PERIOD;   // Shift + . = :
  if (c == '/') return HID_KEY_7;        // Shift + 7 = /
  if (c == '?') return HID_KEY_7;        // Shift + 7 = / (la ? está en la misma tecla)
  if (c == '&') return HID_KEY_6;        // Shift + 6 = &
  if (c == '%') return HID_KEY_5;        // Shift + 5 = %
  if (c == '=') return HID_KEY_0;        // Shift + 0 = =
  if (c == '_') return HID_KEY_MINUS;    // Shift + - = _
  if (c == '#') return HID_KEY_3;        // Shift + 3 = #
  return HID_KEY_SPACE;
}

// ===== COMANDOS SERIE =====
void checkSerialCommands() {
  if (Serial.available() > 0) {
    String command = Serial.readStringUntil('\n');
    command.trim();
    if (command.length() == 0) return;

    if (command.startsWith("SET_KEY:")) {
      int c1 = command.indexOf(':');
      int c2 = command.indexOf(':', c1 + 1);
      int idx = command.substring(c1 + 1, c2).toInt() - 1;
      String macro = command.substring(c2 + 1);
      if (idx >= 0 && idx < 6) {
        keyMacros[idx] = macro;
        Serial.println("OK");
        updateDisplay("Tecla " + String(idx + 1), macro);
      }
    } else if (command.startsWith("SET_POT:")) {
      int c1 = command.indexOf(':');
      int c2 = command.indexOf(':', c1 + 1);
      int idx = command.substring(c1 + 1, c2).toInt() - 1;
      String func = command.substring(c2 + 1);
      if (idx >= 0 && idx < 2) {
        potFunctions[idx] = func;
        Serial.println("OK");
        updateDisplay("Pot " + String(idx + 1), func);
      }
    }
  }
}

// ===== TECLAS =====
void checkKeys() {
  for (int i = 0; i < 6; i++) {
    int reading = digitalRead(KEY_PINS[i]);
    if (reading != lastButtonState[i]) lastDebounceTime[i] = millis();
    if ((millis() - lastDebounceTime[i]) > debounceDelay) {
      if (reading == LOW && keyMacros[i].length() > 0) {
        executeMacro(keyMacros[i]);
        updateDisplay("Tecla " + String(i + 1), keyMacros[i]);
        while (digitalRead(KEY_PINS[i]) == LOW) delay(10);
        delay(100);
      }
    }
    lastButtonState[i] = reading;
  }
}

// ===== POTENCIÓMETROS =====
void checkPotentiometers() {
  for (int i = 0; i < 2; i++) {
    int valorActual = analogRead(POT_PINS[i]);
    int diff = valorActual - lastPotValue[i];
    
    if (abs(diff) > potThreshold && (millis() - lastPotAction) > potCooldown) {
      
      if (potFunctions[i] == "VOLUMEN") {
        if (diff > 0) {
          sendMediaKey(CONSUMER_VOLUME_UP);
        } else {
          sendMediaKey(CONSUMER_VOLUME_DOWN);
        }
        updateDisplay("Volumen", "Cambiando...");
      } else if (potFunctions[i] == "BRILLO") {
        if (diff > 0) {
          sendMediaKey(CONSUMER_BRIGHTNESS_UP);
        } else {
          sendMediaKey(CONSUMER_BRIGHTNESS_DOWN);
        }
        updateDisplay("Brillo", "Cambiando...");
      }
      
      lastPotValue[i] = valorActual;
      lastPotAction = millis();
    }
  }
}
